QN_API_KEY=your_api_key_here
QN_BASE_URL=https://api.qnaigc.com/v1

# DeepSeek code generation model
OPENSCAD_MODEL=claude-4.5-sonnet
OPENSCAD_CHAT_MAX_TOKENS=4096

# Optional messages protocol settings (only used when enabled in code path)
OPENSCAD_API_PROTOCOL=openai-compatible
OPENSCAD_API_PATH=/messages
OPENSCAD_MAX_TOKENS=1024

# Product manager agent (Claude)
PM_ENABLED=true
PM_API_KEY=your_pm_api_key_here
PM_BASE_URL=https://api.qnaigc.com/v1
PM_MODEL=claude-4.5-sonnet
PM_API_PROTOCOL=openai-compatible
PM_API_PATH=/messages
PM_MAX_TOKENS=1024
